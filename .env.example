# Base de datos PostgreSQL
# Host: en tu PC (ETL/API fuera de Docker) usa `localhost`. En Compose el servicio inyecta `db`;
# el ETL detecta ejecución local y reemplaza `db` por 127.0.0.1 si hace falta.
POSTGRES_HOST=localhost
POSTGRES_USER=aedmi_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aedmi_db
POSTGRES_PORT=5432

# API
API_PORT=8080
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRE_HOURS=8

# Autenticación de la app
ADMIN_USER=PhiQus
ADMIN_PASSWORD=change_me_in_production

# Groq API para análisis IA
GROQ_API_KEY=your_groq_api_key_here

# Frontend
FRONTEND_PORT=3000
API_URL=http://localhost:8080

# CORS API (separado por comas)
CORS_ORIGINS=http://localhost:3000

# ETL catálogo pueblos mágicos (opcional)
# CSV remoto con columnas recomendadas: clave,nombre,entidad,municipio,lat,lng,fuente
PUEBLOS_MAGICOS_CSV_URL=

# Producción (solo para .env.prod)
# API_URL=https://tu-dominio.com
