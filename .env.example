# =============================================================
# Variables de entorno para EDMI App
# Copiar a .env y completar con valores reales:
#   cp .env.example .env
# NUNCA commitear el .env real al repositorio.
# =============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=usuario_db
POSTGRES_PASSWORD=cambiar-por-password-seguro
POSTGRES_DB=dash_db
# Puerto expuesto en el host (el contenedor usa 5432 internamente)
POSTGRES_PORT=5433
# Host de conexion: 'db' dentro de Docker, 'localhost' en desarrollo local
POSTGRES_HOST=localhost

# --- Servidor Flask ---
# Puerto externo del servicio web
API_PORT=8080
# Clave secreta para sesiones Flask
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambiar-por-clave-segura-aleatoria

# --- Autenticacion del dashboard ---
APP_USER=usuario_dashboard
APP_PASSWORD=cambiar-por-password-seguro
# 0 = autenticacion activa (produccion), 1 = sin login (solo desarrollo local)
APP_SKIP_AUTH=0

# --- APIs externas ---
# Token INEGI (https://www.inegi.org.mx/servicios/api_indicadores.html)
INEGI_TOKEN=tu-token-inegi-aqui
# Token Banxico (https://www.banxico.org.mx/SieAPIRest/service/v1/)
BANXICO_TOKEN=tu-token-banxico-aqui
# Clave API Groq para analisis IA (https://console.groq.com/)
GROQ_API_KEY=tu-groq-api-key-aqui

# --- Datos externos ---
# URL del Excel de operaciones aeroportuarias
# Actualizar cuando el gobierno publique una nueva version del archivo
AEROPUERTOS_XLSX_URL=https://www.gob.mx/cms/uploads/attachment/file/XXXXXX/producto-aeropuertos-YYYY.xlsx
