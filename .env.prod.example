# Base de datos PostgreSQL
POSTGRES_USER=aedmi_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aedmi_db
POSTGRES_PORT=5432

# API
API_PORT=8080
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRE_HOURS=8

# Autenticación app
ADMIN_USER=PhiQus
ADMIN_PASSWORD=change_me_strong_password

# IA
GROQ_API_KEY=your_groq_api_key_here

# Frontend público
FRONTEND_PORT=3000
API_URL=https://tu-dominio.com/api

# CORS en API (si usas frontend y API en mismo dominio, deja solo tu dominio)
CORS_ORIGINS=https://tu-dominio.com

# ETL catálogo pueblos mágicos (opcional)
PUEBLOS_MAGICOS_CSV_URL=
